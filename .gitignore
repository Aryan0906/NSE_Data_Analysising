# =============================================================
# NSE Stock Market Pipeline — .gitignore
# =============================================================

# --- Secrets (NEVER commit) ---------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
secrets/

# --- Claude Code / IDE personal settings --------------------
.claude/
.vscode/
.idea/
.github/
*.swp
*.swo

# --- Python -------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/
*.so
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
*.cover
.pylintrc

# --- Data / models (large binaries) -------------------------
data/raw/
data/staging/
*.parquet
*.feather
*.pkl
*.h5
*.hdf5
*.ckpt
*.pt
*.pth

# Earnings PDFs — tracked by Git LFS if needed
data/earnings/*.pdf

# --- ChromaDB local data (if not using Docker) ---------------
chromadb_local/
chroma/

# --- Airflow local -----------------------------------------
airflow.db
airflow.cfg
logs/
airflow/logs/
airflow/dags/__pycache__/

# --- Docker -------------------------------------------------
docker_data/

# --- Test & Build outputs -----------------------------------
pip.log
pytest_out*.txt
test_results/
coverage.xml

# --- IDE / OS -----------------------------------------------
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- Jupyter ------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# --- Node (Streamlit custom components if any) ---------------
node_modules/

# --- Local documentation -------------------------------------
REALTIME_SETUP.md
